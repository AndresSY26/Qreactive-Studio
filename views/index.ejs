  <!--
    Formulario oculto para descargas — el navegador sigue la respuesta del servidor
    con Content-Disposition: attachment y respeta el nombre de archivo en todos los browsers.
    Los valores de data, ext y filename se rellenan desde main.js antes del submit.
  -->
  <form
    id="dl-form"
    method="POST"
    action="/api/download"
    style="display:none;"
    aria-hidden="true"
  >
    <input type="hidden" name="data"     id="dl-data"     value="" />
    <input type="hidden" name="ext"      id="dl-ext"      value="" />
    <input type="hidden" name="filename" id="dl-filename" value="" />
  </form>

  <!-- Toast notification -->
  <div class="toast" id="toast" role="alert" aria-live="polite"></div>


